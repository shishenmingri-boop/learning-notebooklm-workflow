# Pinterest API
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:8765/callback
PINTEREST_TOKEN_PATH=.pinterest-oauth-token.json
# true にすると sandbox API を使用
PINTEREST_SANDBOX=false

# Flux image generation (Replicate)
REPLICATE_API_TOKEN=

# CDN upload (Cloudflare R2 or S3-compatible)
CDN_PROVIDER=r2
CDN_ACCESS_KEY_ID=
CDN_SECRET_ACCESS_KEY=
CDN_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
CDN_REGION=auto
CDN_BUCKET=

# note.com (Playwright login)
NOTE_EMAIL=
NOTE_PASSWORD=
